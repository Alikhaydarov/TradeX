SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
PORT=8000
NGROK_AUTHTOKEN=YOUR_NGROK_AUTHTOKEN
MT5_DEFAULT_SERVER=Exness-MT5Trial15

# Must match the same value in Vercel.
MT5_CONNECTOR_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Live auto-sync delay. 15 = checks every 15 seconds.
MT5_SYNC_INTERVAL_SECONDS=15

# Live sync must stay small so one big history account cannot delay other users.
# Full old history/backfill can still use MT5_LOOKBACK_DAYS through manual sync/backfill.
MT5_AUTO_LOOKBACK_DAYS=3

# Full/manual history lookback.
MT5_LOOKBACK_DAYS=1825

# Optional: exact MT5 terminal path on the VPS.
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
